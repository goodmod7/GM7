# Core runtime
NODE_ENV=production
PORT=3001
LOG_LEVEL=info
DEPLOYMENT_MODE=single_instance

# Database + cache
POSTGRES_PASSWORD=change_me
POSTGRES_DB=ai_operator
DATABASE_URL=postgresql://postgres:change_me@postgres:5432/ai_operator
REDIS_URL=redis://redis:6379
RATE_LIMIT_BACKEND=redis

# Auth + origins
WEB_ORIGIN=https://app.example.com
APP_BASE_URL=https://app.example.com
API_PUBLIC_BASE_URL=https://api.example.com
ALLOW_INSECURE_DEV=false
JWT_SECRET=replace_with_long_random_secret
ADMIN_API_KEY=replace_with_admin_key

# Metrics safety: keep false on public internet
METRICS_PUBLIC=false

# Billing (set BILLING_ENABLED=false if you are not using Stripe)
BILLING_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# Release metadata
DESKTOP_RELEASE_SOURCE=file
GITHUB_REPO_OWNER=
GITHUB_REPO_NAME=
GITHUB_TOKEN=
DESKTOP_RELEASE_CACHE_TTL_SECONDS=60
DESKTOP_RELEASE_TAG=latest
DESKTOP_UPDATE_FEED_DIR=./updates
DESKTOP_UPDATE_ENABLED=true
DESKTOP_VERSION=0.1.0
DESKTOP_WIN_URL=https://example.com/downloads/ai-operator-setup.exe
DESKTOP_MAC_INTEL_URL=https://example.com/downloads/ai-operator-macos-intel.dmg
DESKTOP_MAC_ARM_URL=https://example.com/downloads/ai-operator-macos-apple-silicon.dmg

# Recovery policy
RUN_RECOVERY_POLICY=fail

# Data retention
AUDIT_RETENTION_DAYS=30
STRIPE_EVENT_RETENTION_DAYS=30
SESSION_RETENTION_DAYS=30
RUN_RETENTION_DAYS=90
