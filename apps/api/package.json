{
  "name": "@ai-operator/api",
  "version": "0.0.6",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node scripts/start-with-migrate.mjs",
    "start:node": "node dist/index.js",
    "migrate:deploy": "prisma migrate deploy",
    "prisma:generate": "prisma generate",
    "retention:run-once": "tsx scripts/run-retention.ts",
    "test": "node --test --test-force-exit test/**/*.test.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-operator/shared": "workspace:*",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/websocket": "^11.2.0",
    "@prisma/client": "^6.17.1",
    "argon2": "^0.44.0",
    "fastify": "^5.1.0",
    "fastify-raw-body": "^5.0.0",
    "jsonwebtoken": "^9.0.3",
    "prisma": "^6.17.1",
    "stripe": "^20.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
