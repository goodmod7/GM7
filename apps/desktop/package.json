{
  "name": "@ai-operator/desktop",
  "version": "0.0.12",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build:debug": "tauri build --debug",
    "check:rust:fmt": "cargo fmt --manifest-path src-tauri/Cargo.toml --check",
    "check:rust:clippy": "cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets --all-features -- -D warnings",
    "tauri:check": "pnpm run check:rust:fmt && pnpm run check:rust:clippy && pnpm run tauri:build:debug",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "check:csp": "node ../../scripts/check-desktop-csp.mjs"
  },
  "dependencies": {
    "@ai-operator/shared": "workspace:*",
    "@tauri-apps/api": "^2.2.0",
    "@tauri-apps/plugin-opener": "^2.2.0",
    "@tauri-apps/plugin-dialog": "^2.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.2.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  }
}
