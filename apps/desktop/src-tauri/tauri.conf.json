{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI Operator Desktop",
  "version": "0.0.4",
  "identifier": "com.ai-operator.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AI Operator Desktop",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  },
  "plugins": {
    "dialog": {},
    "updater": {
      "active": true,
      "dialog": true,
      "pubkey": "${VITE_DESKTOP_UPDATER_PUBLIC_KEY}",
      "endpoints": [
        "${VITE_API_HTTP_BASE}/updates/desktop/{{platform}}/{{arch}}/{{current_version}}.json"
      ]
    }
  }
}
